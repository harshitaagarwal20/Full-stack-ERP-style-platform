PORT=5000
# Local dev: a plain mysql:// URL. On Hostinger production set this to the
# Prisma Accelerate URL (prisma://accelerate.prisma-data.net/?api_key=...) so
# the query engine runs in Prisma's cloud and avoids the "timer has gone away"
# panic on Hostinger's throttled runtime.
DATABASE_URL="mysql://root:root@localhost:3306/nimbasia"
# Only needed in production when DATABASE_URL is a prisma:// Accelerate URL:
# the raw mysql:// connection used by `prisma migrate`/`db` (Accelerate can't
# run migrations). Leave unset for local dev.
# DIRECT_DATABASE_URL="mysql://user:pass@srv1852.hstgr.io:3306/nimbasia"
JWT_SECRET="change_this_to_a_strong_secret_at_least_32_chars"
JWT_EXPIRES_IN="7d"
AUDIT_LOG_RETENTION_DAYS=30

# Shared secret authorizing the audit-retention cron endpoint
# (/api/cron/audit-retention). Send it as `x-cron-secret: <value>` or
# `Authorization: Bearer <value>`. Without it the endpoint returns 403.
CRON_SECRET="change_this_to_a_strong_cron_secret"

# CORS Origins - Add your frontend URLs separated by commas
# For local development: http://localhost:5174,http://127.0.0.1:5174,http://localhost:4173,http://127.0.0.1:4173
# For production: https://app.nimbasia.com
# For network access: Add http://<your-machine-ip>:5174 or :4173
# To find your machine IP: Run `ipconfig` (Windows) or `ifconfig` (Mac/Linux)
CLIENT_ORIGIN="http://localhost:5174,http://127.0.0.1:5174,http://localhost:4173,http://127.0.0.1:4173,https://app.nimbasia.com"
