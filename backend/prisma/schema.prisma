generator client {
  provider      = "prisma-client-js"
  // Run the in-process Node-API "library" engine (Prisma's default). On
  // Hostinger's shared runtime the out-of-process "binary" engine's child
  // process gets CPU-throttled/killed, which kills its timer thread and panics
  // ("timer has gone away"). The in-process library engine avoids that extra
  // process. binaryTargets pins Hostinger's platform (debian-openssl-1.1.x).
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  sales
  production
  dispatch
  // Raises purchase orders (supplier, items, quantities) but never sees or
  // sets pricing, and cannot release a PO to the supplier.
  purchase
  // Owns the money side of a PO: unit price, tax, currency, discount and
  // freight — and releases the priced PO to the supplier.
  accounts
}

enum EnquiryStatus {
  PENDING
  ACCEPTED
  HOLD
  REJECTED
}

// Sales progress of an enquiry. Independent of EnquiryStatus, which drives
// the approval workflow.
enum EnquiryStage {
  GENERAL
  SAMPLED
  QUOTED
}

enum OrderStatus {
  CREATED
  IN_PRODUCTION
  READY_FOR_DISPATCH
  PARTIALLY_DISPATCHED
  COMPLETED
  DISPATCHED
}

enum ManualOrderRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  ORDER_CREATED
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  PARTIALLY_PRODUCED
  HOLD
  // A batch whose finished-goods QC failed. It holds no sellable stock (the
  // inward sync zeroes it), and stays here until production resumes work on it.
  REWORK
  COMPLETED
}

enum Unit {
  KG
  MT
  LTR
}

enum ShipmentStatus {
  PACKING
  SHIPPED
  DELIVERED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  SENT_TO_SUPPLIER
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CLOSED
}

enum GrnStatus {
  DRAFT
  CONFIRMED
  // The raw material failed its test sheet and the consignment was turned away.
  // A rejected GRN can never be confirmed, so none of it reaches inventory.
  REJECTED
}

enum QcResult {
  PENDING
  PASS
  FAIL
}

enum FgQcResult {
  PENDING
  PASS
  FAIL
}

// Accounts tracks payment after the goods ship. An order is only COMPLETED once
// it is both fully dispatched and paid — dispatch alone leaves it DISPATCHED.
enum PaymentStatus {
  PENDING
  PARTIAL
  RECEIVED
}

model User {
  id                 Int       @id @default(autoincrement())
  name               String
  email              String    @unique
  password           String
  role               Role
  createdAt          DateTime  @default(now())
  passwordChangedAt  DateTime?
  enquiriesCreated   Enquiry[] @relation("EnquiryCreator")
  enquiriesApproved  Enquiry[] @relation("EnquiryApprover")
  ordersCreated      Order[]
  manualOrderRequestsCreated ManualOrderRequest[] @relation("ManualOrderRequestCreator")
  manualOrderRequestsApproved ManualOrderRequest[] @relation("ManualOrderRequestApprover")
  auditLogs          AuditLog[]
  purchaseOrders     PurchaseOrder[] @relation("POCreator")
  batchSubstitutions BatchSubstitution[]

  @@index([createdAt, id])
  @@index([role, createdAt])
}

enum PermissionLevel {
  NONE
  VIEW
  FULL
}

// Admin-editable module access per role. Admin itself is never stored here —
// it always has full access, so that no admin can lock every admin out of the
// permissions screen.
model RolePermission {
  id        Int             @id @default(autoincrement())
  role      Role
  module    String
  level     PermissionLevel @default(NONE)
  updatedAt DateTime        @updatedAt

  @@unique([role, module])
  @@index([role])
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  addresses           CustomerAddress[]
  enquiries           Enquiry[]
  orders              Order[]
  manualOrderRequests ManualOrderRequest[]

  @@unique([name])
  @@index([name])
}

model CustomerAddress {
  id          Int       @id @default(autoincrement())
  customerId  Int
  address     String
  city        String?
  pincode     String?
  state       String?
  countryCode String?
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String
  entityId   Int?
  actorId    Int?
  actorName  String?
  actorRole  Role?
  oldValue   Json?
  newValue   Json?
  note       String?
  createdAt  DateTime @default(now())

  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([createdAt])
}

model Enquiry {
  id               Int           @id @default(autoincrement())
  enquiryNumber    String?
  companyName      String
  customerId       Int?
  customerAddressId Int?
  product          String
  products         Json?
  // Allow fractional enquiry quantities (e.g., 2.5 kg)
  quantity         Float
  price            Float?
  currency         String?
  unitOfMeasurement String?
  enquiryDate      DateTime?
  modeOfEnquiry    String?
  customerType     String?
  enquiryType      String?
  incoTerm         String?
  country          String?
  port             String?
  lastTransaction  String?
  expectedTimeline DateTime?
  assignedPerson   String
  notesForProduction String?
  remarks          String?
  status           EnquiryStatus @default(PENDING)
  stage            EnquiryStage  @default(GENERAL)
  // Set the first time the enquiry enters SAMPLED; drives the 12-day
  // follow-up reminder.
  sampledAt        DateTime?
  // Urgent enquiries jump the production queue and can auto-create the
  // downstream order + production job.
  isUrgent         Boolean       @default(false)
  // Captured when an enquiry is rejected at approval.
  rejectionReason  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  createdById      Int
  approvedById     Int?
  customer         Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy        User          @relation("EnquiryCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy       User?         @relation("EnquiryApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  order            Order?

  @@index([customerId])
  @@index([status, createdAt])
  @@index([stage])
  @@index([enquiryDate])
  @@index([expectedTimeline])
}

model BillOfMaterial {
  id        Int      @id @default(autoincrement())
  product   String
  grade     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items BillOfMaterialItem[]

  @@unique([product, grade])
  @@index([product])
}

model BillOfMaterialItem {
  id         Int     @id @default(autoincrement())
  bomId      Int
  category   String
  name       String
  vendor     String?
  grade      String?
  qtyPerUnit Float
  remark     String?

  bom BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@index([bomId])
}

model Order {
  id               Int         @id @default(autoincrement())
  enquiryId        Int?        @unique
  customerId       Int?
  customerAddressId Int?
  salesGroupNumber String?
  salesOrderNumber String      @unique
  orderNo          String      @unique
  product          String
  grade            String
  quantity         Float
  price            Float?
  currency         String?
  unit             Unit
  packingType      String
  packingSize      String
  deliveryDate     DateTime
  clientName       String
  address          String?
  city             String?
  pincode          String?
  state            String?
  countryCode      String?
  dispatchDate     DateTime?
  status           OrderStatus @default(CREATED)
  paymentStatus    PaymentStatus @default(PENDING)
  amountReceived   Float?
  paymentReceivedAt DateTime?
  paymentRemarks   String?
  // Propagated from the source enquiry. Urgent orders are pulled to the front
  // of the production queue; everything else is FIFO by creation date.
  isUrgent         Boolean     @default(false)
  orderDate        DateTime    @default(now())
  remarks          String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  createdById      Int
  customer         Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  enquiry          Enquiry?    @relation(fields: [enquiryId], references: [id], onDelete: Restrict)
  createdBy        User        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  productions      Production[]
  dispatches       Dispatch[]
  packingRecords   PackingRecord[]
  manualOrderRequest ManualOrderRequest? @relation("ManualOrderRequestToOrder")

  @@index([customerId])
  // The list filters on status and sorts by status then createdAt — without this
  // every page load is a full table scan plus a filesort.
  @@index([status, createdAt])
  @@index([orderDate])
  @@index([deliveryDate])
}

model ManualOrderRequest {
  id             Int                     @id @default(autoincrement())
  requestNumber  String
  customerId     Int?
  customerAddressId Int?
  product        String
  grade          String
  quantity       Float
  unit           String
  packingType    String
  packingSize    String
  dispatchDate   DateTime?
  clientName     String
  address        String?
  city           String?
  pincode        String?
  state          String?
  countryCode    String?
  remarks        String?
  status         ManualOrderRequestStatus @default(REQUESTED)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  createdById    Int
  approvedById   Int?
  orderId        Int?                    @unique
  customer       Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy      User                    @relation("ManualOrderRequestCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy     User?                   @relation("ManualOrderRequestApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  order          Order?                  @relation("ManualOrderRequestToOrder", fields: [orderId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requestNumber])
  @@index([customerId])
}

model Production {
  id                       Int              @id @default(autoincrement())
  orderId                  Int
  status                   ProductionStatus @default(PENDING)
  statusChangeCount        Int              @default(0)
  state                    String?
  assignedPersonnel        String
  deliveryDate             DateTime
  productSpecs             String
  capacity                 Float
  batchNo                  String?
  particleSize             String
  acmRpm                   Int
  classifierRpm            Int
  blowerRpm                Int
  rawMaterials             String?          @db.LongText
  productRemark            String?
  remarks                  String?          @db.LongText
  productionStartedDate    DateTime?
  productionCompletionDate DateTime?
  producedQuantity         Float              @default(0)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  order                    Order            @relation(fields: [orderId], references: [id], onDelete: Restrict)
  finishedGoodsTestSheet   FinishedGoodsTestSheet?
  inProcessTestSheet       InProcessTestSheet?
  batchSubstitutions       BatchSubstitution[]

  @@index([orderId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model InProcessTestSheet {
  id           Int      @id @default(autoincrement())
  productionId Int      @unique
  productName  String?
  grade        String?
  batchNo      String?
  // The "quality check in between project" gate: a FAIL sends the batch to
  // REWORK before it ever reaches packing.
  overallResult FgQcResult @default(PENDING)
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  production Production                @relation(fields: [productionId], references: [id], onDelete: Cascade)
  items      InProcessTestSheetItem[]
}

model InProcessTestSheetItem {
  id                   Int       @id @default(autoincrement())
  inProcessTestSheetId Int
  analysisDate         DateTime?
  shift                String?
  lotNo                String?
  reactorNo            String?
  samplingBy           String?
  samplingTime         String?
  freeFattyAcid        String?
  ash                  String?
  moisture             String?
  appearance           String?
  meltingPoint         String?
  analysisBy           String?
  ffaInformTime        String?
  remarks              String?

  inProcessTestSheet InProcessTestSheet @relation(fields: [inProcessTestSheetId], references: [id], onDelete: Cascade)

  @@index([inProcessTestSheetId])
}

model FinishedGoodsTestSheet {
  id            Int        @id @default(autoincrement())
  productionId  Int        @unique
  productName   String?
  grade         String?
  batchNo       String?
  overallResult FgQcResult @default(PENDING)
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  production Production                   @relation(fields: [productionId], references: [id], onDelete: Cascade)
  items      FinishedGoodsTestSheetItem[]
}

model FinishedGoodsTestSheetItem {
  id            Int       @id @default(autoincrement())
  sheetId       Int
  srNo          Int?
  sampleDate    DateTime?
  shift         String?
  samplingBy    String?
  samplingTime  String?
  blackParticle String?
  bulkDensity   String?
  sieveResidue  String?
  analysisBy    String?
  approvedBy    String?
  remarks       String?

  sheet FinishedGoodsTestSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@index([sheetId])
}

model Dispatch {
  id             Int            @id @default(autoincrement())
  orderId        Int
  dispatchedQuantity Float
  dispatchDate   DateTime       @default(now())
  packingDone    Boolean
  shipmentStatus ShipmentStatus
  remarks        String?
  createdAt      DateTime       @default(now())
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)

  // Every other list model carries these; Dispatch was the one gap. The list
  // sorts by createdAt, and orderId is joined on constantly (dispatch history
  // per order), so both want an index rather than a scan.
  @@index([orderId])
  @@index([createdAt, id])
}

// Records finished goods being packed for an order, consuming packing
// material (bags/cartons/etc.) from inventory. Dispatch quantity is capped
// by (total packed - already dispatched) for the order, so "packed" is an
// enforced fact rather than a free checkbox.
model PackingRecord {
  id                    Int      @id @default(autoincrement())
  orderId               Int
  packedQuantity        Float
  packingMaterialItemId String
  packingMaterialQty    Float
  packedBy              String?
  remarks               String?
  createdAt             DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model Supplier {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  supplierCode  String?
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  pincode       String?
  gstNo         String?
  panNo         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([name])
}

model PurchaseOrder {
  id                   Int                 @id @default(autoincrement())
  poNumber             String              @unique
  poNumberWithCategory String?
  category             String?
  billTo               String?
  shipTo               String?
  supplierId           Int
  orderDate            DateTime            @default(now())
  expectedDeliveryDate DateTime?
  totalDiscount        Float               @default(0)
  freight              String?
  status               PurchaseOrderStatus @default(DRAFT)
  totalAmount          Float               @default(0)
  notes                String?             @db.Text
  department           String?
  createdById          Int
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy User                @relation("POCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items     PurchaseOrderItem[]
  grns      GoodsReceiptNote[]

  @@index([status, createdAt])
  @@index([supplierId])
  @@index([orderDate])
}

model PurchaseOrderItem {
  id          Int      @id @default(autoincrement())
  uniqueKey   String   @unique
  poId        Int
  poNumber    String
  supplier    String
  itemId      String
  category    String?
  uom         String?
  grade       String?
  currency    String   @default("INR")
  unitPrice   Float    @default(0)
  taxPercent  Float    @default(0)
  expDaysDelivery String?
  qty         Float
  receivedQty Float    @default(0)
  outwardKey  String?
  batchNo     String?
  remark      String?
  createdAt   DateTime @default(now())
  receivedAt  DateTime?

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  grnItems      GrnItem[]

  @@index([poId])
}

model GoodsReceiptNote {
  id                Int       @id @default(autoincrement())
  grnNumber         String    @unique
  poId              Int
  receivedDate      DateTime  @default(now())
  receivedBy        String?
  vehicleRef        String?
  warehouseLocation String?
  status            GrnStatus @default(DRAFT)
  // Why the consignment was turned away — the only record of the decision.
  rejectionReason   String?
  rejectedAt        DateTime?
  remarks           String?   @db.Text
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  purchaseOrder          PurchaseOrder          @relation(fields: [poId], references: [id], onDelete: Restrict)
  items                  GrnItem[]
  inventoryTransactions  InventoryTransaction[]
  qcTestSheet            QcTestSheet?

  @@index([poId])
  @@index([status])
}

model GrnItem {
  id               Int              @id @default(autoincrement())
  grnId            Int
  poItemId         Int
  itemId           String
  category         String?
  grade            String?
  uom              String?
  currency         String?
  unitPrice        Float?
  taxPercent       Float?
  batchNo          String?
  quantityOrdered  Float
  quantityReceived Float            @default(0)
  remarks          String?

  grn    GoodsReceiptNote  @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poItem PurchaseOrderItem @relation(fields: [poItemId], references: [id], onDelete: Restrict)

  @@index([grnId])
  @@index([poItemId])
}

model QcTestSheet {
  id            Int       @id @default(autoincrement())
  grnId         Int       @unique
  sheetNumber   String?
  overallResult QcResult  @default(PENDING)
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  grn   GoodsReceiptNote  @relation(fields: [grnId], references: [id], onDelete: Cascade)
  items QcTestSheetItem[]
}

model QcTestSheetItem {
  id            Int       @id @default(autoincrement())
  qcTestSheetId Int
  srNo          Int?
  samplingDate  DateTime?
  productName   String
  batchNo       String?
  mfgDate       DateTime?
  expiryDate    DateTime?
  supplier      String?
  sampleQty     Float?
  testParameter String?
  result        String?
  analysisBy    String?
  analysisDate  DateTime?
  remarks       String?

  qcTestSheet QcTestSheet @relation(fields: [qcTestSheetId], references: [id], onDelete: Cascade)

  @@index([qcTestSheetId])
}

model InventoryTransaction {
  id                Int               @id @default(autoincrement())
  type              String
  itemId            String
  quantity          Float
  warehouseLocation String?
  reference         String?
  grnId             Int?
  grnItemId         Int?
  remarks           String?
  category          String?
  uom               String?
  grade             String?
  batchNo           String?
  shift             String?
  importBatch       String?
  createdAt         DateTime          @default(now())

  grn GoodsReceiptNote? @relation(fields: [grnId], references: [id], onDelete: SetNull)
  substitutionReversalOf    BatchSubstitution? @relation("SubstitutionReversal")
  substitutionConsumptionOf BatchSubstitution? @relation("SubstitutionConsumption")

  @@index([itemId])
  @@index([itemId, batchNo])
  @@index([grnId])
  @@index([reference])
  @@index([createdAt])
  @@index([type, createdAt])
}

model BatchSubstitution {
  id                        Int      @id @default(autoincrement())
  productionId              Int
  section                   String
  originalItemId            String
  originalBatchNo           String
  originalVendor            String?
  originalGrade             String?
  quantity                  Float
  substituteItemId          String
  substituteBatchNo         String
  substituteVendor          String?
  substituteGrade           String?
  reason                    String?
  reversalTransactionId     Int      @unique
  consumptionTransactionId  Int      @unique
  createdById                Int
  createdAt                  DateTime @default(now())

  production             Production           @relation(fields: [productionId], references: [id], onDelete: Cascade)
  reversalTransaction    InventoryTransaction @relation("SubstitutionReversal", fields: [reversalTransactionId], references: [id])
  consumptionTransaction InventoryTransaction @relation("SubstitutionConsumption", fields: [consumptionTransactionId], references: [id])
  createdBy              User                 @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([productionId])
}

// ---------------------------------------------------------------------------
// Master tables.
//
// These five were created at runtime by raw DDL in masterDataService rather than
// by Prisma, which left the schema with two sources of truth: Prisma did not
// know they existed, so `prisma migrate dev` would have generated a migration
// that DROPPED all five — taking the customer, supplier and product masters and
// every dropdown list in the app with them. Declaring them here closes that.
//
// The field types below mirror the live tables exactly. masterDataService still
// creates them with CREATE TABLE IF NOT EXISTS on boot, which is now a harmless
// no-op on any database Prisma has already migrated.
// ---------------------------------------------------------------------------

/// Every admin-editable dropdown list in the app (products, units, suppliers of
/// names, packing materials, ...), keyed by category.
model MasterDataItem {
  id        Int      @id @default(autoincrement())
  category  String   @db.VarChar(100)
  value     String   @db.VarChar(191)
  label     String?  @db.VarChar(191)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([category, value], map: "MasterDataItem_category_value_key")
  @@index([category, sortOrder], map: "MasterDataItem_category_sortOrder_idx")
}

model EnquiryMaster {
  id             Int      @id @default(autoincrement())
  modeOfEnquiry  String   @db.VarChar(191)
  companyName    String   @db.VarChar(191)
  product        String   @db.VarChar(191)
  assignedPerson String   @db.VarChar(191)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@unique([modeOfEnquiry, companyName, product, assignedPerson], map: "EnquiryMaster_unique_key")
}

model CustomerMaster {
  id                  Int      @id @default(autoincrement())
  customerName        String   @db.VarChar(191)
  gstn                String?  @db.VarChar(50)
  country             String?  @db.VarChar(100)
  countryCode         String?  @db.VarChar(20)
  custInitials        String?  @db.VarChar(20)
  sNoCode             String?  @db.VarChar(50)
  customerCode        String?  @unique(map: "CustomerMaster_customerCode_key") @db.VarChar(80)
  contactPerson       String?  @db.VarChar(191)
  contactPersonNumber String?  @db.VarChar(30)
  companyEmail        String?  @db.VarChar(191)
  address             String?  @db.VarChar(500)
  pincode             String?  @db.VarChar(20)
  state               String?  @db.VarChar(100)
  city                String?  @db.VarChar(100)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt
}

model SupplierMaster {
  id                  Int      @id @default(autoincrement())
  supplierName        String   @db.VarChar(191)
  gstn                String?  @db.VarChar(50)
  panNo               String?  @db.VarChar(20)
  country             String?  @db.VarChar(100)
  countryCode         String?  @db.VarChar(20)
  supplierCode        String?  @unique(map: "SupplierMaster_supplierCode_key") @db.VarChar(80)
  contactPerson       String?  @db.VarChar(191)
  contactPersonNumber String?  @db.VarChar(30)
  companyEmail        String?  @db.VarChar(191)
  address             String?  @db.VarChar(500)
  pincode             String?  @db.VarChar(20)
  state               String?  @db.VarChar(100)
  city                String?  @db.VarChar(100)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt
}

/// The product master behind every product picker: the name is what the pickers
/// bind to, the category and attributes are what a plain name cannot carry.
model ProductMaster {
  id          Int      @id @default(autoincrement())
  productName String   @unique(map: "ProductMaster_productName_key") @db.VarChar(191)
  category    String?  @db.VarChar(100)
  defaultUnit String?  @db.VarChar(20)
  hsnCode     String?  @db.VarChar(30)
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([category], map: "ProductMaster_category_idx")
}
