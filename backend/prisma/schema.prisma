generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  sales
  production
  dispatch
}

enum EnquiryStatus {
  PENDING
  ACCEPTED
  HOLD
  REJECTED
}

enum OrderStatus {
  CREATED
  IN_PRODUCTION
  READY_FOR_DISPATCH
  PARTIALLY_DISPATCHED
  COMPLETED
  DISPATCHED
}

enum ManualOrderRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  ORDER_CREATED
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  HOLD
  COMPLETED
}

enum Unit {
  KG
  MT
  LTR
}

enum ShipmentStatus {
  PACKING
  SHIPPED
  DELIVERED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  SENT_TO_SUPPLIER
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CLOSED
}

enum GrnStatus {
  DRAFT
  CONFIRMED
}

model User {
  id                 Int       @id @default(autoincrement())
  name               String
  email              String    @unique
  password           String
  role               Role
  createdAt          DateTime  @default(now())
  enquiriesCreated   Enquiry[] @relation("EnquiryCreator")
  enquiriesApproved  Enquiry[] @relation("EnquiryApprover")
  ordersCreated      Order[]
  manualOrderRequestsCreated ManualOrderRequest[] @relation("ManualOrderRequestCreator")
  manualOrderRequestsApproved ManualOrderRequest[] @relation("ManualOrderRequestApprover")
  auditLogs          AuditLog[]
  purchaseOrders     PurchaseOrder[] @relation("POCreator")

  @@index([createdAt, id])
  @@index([role, createdAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String
  entityId   Int?
  actorId    Int?
  actorName  String?
  actorRole  Role?
  oldValue   Json?
  newValue   Json?
  note       String?
  createdAt  DateTime @default(now())

  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([createdAt])
}

model Enquiry {
  id               Int           @id @default(autoincrement())
  enquiryNumber    String?
  companyName      String
  product          String
  products         Json?
  quantity         Int
  price            Float?
  currency         String?
  unitOfMeasurement String?
  enquiryDate      DateTime?
  modeOfEnquiry    String?
  expectedTimeline DateTime?
  assignedPerson   String
  notesForProduction String?
  remarks          String?
  status           EnquiryStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  createdById      Int
  approvedById     Int?
  createdBy        User          @relation("EnquiryCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy       User?         @relation("EnquiryApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  order            Order?
}

model Order {
  id               Int         @id @default(autoincrement())
  enquiryId        Int?        @unique
  salesGroupNumber String?
  salesOrderNumber String      @unique
  orderNo          String      @unique
  product          String
  grade            String
  quantity         Int
  price            Float?
  currency         String?
  unit             Unit
  packingType      String
  packingSize      String
  deliveryDate     DateTime
  clientName       String
  address          String?
  city             String?
  pincode          String?
  state            String?
  countryCode      String?
  dispatchDate     DateTime?
  status           OrderStatus @default(CREATED)
  orderDate        DateTime    @default(now())
  remarks          String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  createdById      Int
  enquiry          Enquiry?    @relation(fields: [enquiryId], references: [id], onDelete: Restrict)
  createdBy        User        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  production       Production?
  dispatches       Dispatch[]
  manualOrderRequest ManualOrderRequest? @relation("ManualOrderRequestToOrder")
}

model ManualOrderRequest {
  id             Int                     @id @default(autoincrement())
  requestNumber  String
  product        String
  grade          String
  quantity       Int
  unit           String
  packingType    String
  packingSize    String
  dispatchDate   DateTime?
  clientName     String
  address        String?
  city           String?
  pincode        String?
  state          String?
  countryCode    String?
  remarks        String?
  status         ManualOrderRequestStatus @default(REQUESTED)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  createdById    Int
  approvedById   Int?
  orderId        Int?                    @unique
  createdBy      User                    @relation("ManualOrderRequestCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy     User?                   @relation("ManualOrderRequestApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  order          Order?                  @relation("ManualOrderRequestToOrder", fields: [orderId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requestNumber])
}

model Production {
  id                       Int              @id @default(autoincrement())
  orderId                  Int              @unique
  status                   ProductionStatus @default(PENDING)
  statusChangeCount        Int              @default(0)
  state                    String?
  assignedPersonnel        String
  deliveryDate             DateTime
  productSpecs             String
  capacity                 Int
  batchNo                  String?
  particleSize             String
  acmRpm                   Int
  classifierRpm            Int
  blowerRpm                Int
  rawMaterials             String?          @db.LongText
  remarks                  String?          @db.LongText
  productionCompletionDate DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  order                    Order            @relation(fields: [orderId], references: [id], onDelete: Restrict)
}

model Dispatch {
  id             Int            @id @default(autoincrement())
  orderId        Int
  dispatchedQuantity Int
  dispatchDate   DateTime       @default(now())
  packingDone    Boolean
  shipmentStatus ShipmentStatus
  remarks        String?
  createdAt      DateTime       @default(now())
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)
}

model Supplier {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  supplierCode  String?
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  pincode       String?
  gstNo         String?
  panNo         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([name])
}

model PurchaseOrder {
  id                   Int                 @id @default(autoincrement())
  poNumber             String              @unique
  poNumberWithCategory String?
  category             String?
  billTo               String?
  supplierId           Int
  orderDate            DateTime            @default(now())
  expectedDeliveryDate DateTime?
  totalDiscount        Float               @default(0)
  freight              String?
  status               PurchaseOrderStatus @default(DRAFT)
  totalAmount          Float               @default(0)
  notes                String?             @db.Text
  department           String?
  createdById          Int
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy User                @relation("POCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items     PurchaseOrderItem[]
  grns      GoodsReceiptNote[]

  @@index([status, createdAt])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id          Int      @id @default(autoincrement())
  uniqueKey   String   @unique
  poId        Int
  poNumber    String
  supplier    String
  itemId      String
  category    String?
  uom         String?
  grade       String?
  currency    String   @default("INR")
  unitPrice   Float    @default(0)
  taxPercent  Float    @default(0)
  expDaysDelivery String?
  qty         Int
  receivedQty Int      @default(0)
  outwardKey  String?
  batchNo     String?
  createdAt   DateTime @default(now())
  receivedAt  DateTime?

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  grnItems      GrnItem[]

  @@index([poId])
}

model GoodsReceiptNote {
  id                Int       @id @default(autoincrement())
  grnNumber         String    @unique
  poId              Int
  receivedDate      DateTime  @default(now())
  receivedBy        String?
  vehicleRef        String?
  warehouseLocation String?
  status            GrnStatus @default(DRAFT)
  remarks           String?   @db.Text
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  purchaseOrder          PurchaseOrder          @relation(fields: [poId], references: [id], onDelete: Restrict)
  items                  GrnItem[]
  inventoryTransactions  InventoryTransaction[]

  @@index([poId])
  @@index([status])
}

model GrnItem {
  id               Int              @id @default(autoincrement())
  grnId            Int
  poItemId         Int
  itemId           String
  category         String?
  grade            String?
  uom              String?
  currency         String?
  unitPrice        Float?
  taxPercent       Float?
  batchNo          String?
  quantityOrdered  Int
  quantityReceived Int              @default(0)
  remarks          String?

  grn    GoodsReceiptNote  @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poItem PurchaseOrderItem @relation(fields: [poItemId], references: [id], onDelete: Restrict)

  @@index([grnId])
  @@index([poItemId])
}

model InventoryTransaction {
  id                Int               @id @default(autoincrement())
  type              String
  itemId            String
  quantity          Int
  warehouseLocation String?
  reference         String?
  grnId             Int?
  grnItemId         Int?
  remarks           String?
  createdAt         DateTime          @default(now())

  grn GoodsReceiptNote? @relation(fields: [grnId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([grnId])
}
