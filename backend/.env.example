PORT=5000
DATABASE_URL="mysql://root:root@localhost:3306/nimbasia"
JWT_SECRET="change_this_to_a_strong_secret"
JWT_EXPIRES_IN="30d"
AUDIT_LOG_RETENTION_DAYS=30

# CORS Origins - Add your frontend URLs separated by commas
# For local development: http://localhost:5174,http://127.0.0.1:5174,http://localhost:4173,http://127.0.0.1:4173
# For Vercel production: https://nimbasia.vercel.app
# For Vercel previews: https://*.vercel.app
# For network access: Add http://<your-machine-ip>:5174 or :4173
# To find your machine IP: Run `ipconfig` (Windows) or `ifconfig` (Mac/Linux)
CLIENT_ORIGIN="http://localhost:5174,http://127.0.0.1:5174,http://localhost:4173,http://127.0.0.1:4173,https://nimbasia.vercel.app,https://*.vercel.app"
