RewriteEngine On

# Let the Node backend handle API calls — never rewrite /api to the SPA.
# (Only matters when the frontend and /api share one domain; harmless otherwise.)
RewriteRule ^api(/|$) - [L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.html [L]
